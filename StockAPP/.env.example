# DataSource runtime config
# Proxy patch (optional)
AKSHARE_ENABLE_PROXY=false
AKSHARE_PROXY_HOST=101.201.173.125
AKSHARE_PROXY_TIMEOUT=30
PROXY_AUTH_CODE=

# Tushare token (optional, required for historical index components)
TUSHARE_TOKEN=

# Optional toggles
DATA_ENABLE_FALLBACK=true
DATA_CACHE_EXPIRE_HOURS=4

# Storage backend: pkl | dual | mysql
DATA_STORAGE_BACKEND=mysql

# MySQL (local docker default)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=stockapp
MYSQL_USER=stockapp
MYSQL_PASSWORD=stockapp
MYSQL_CHARSET=utf8mb4
MYSQL_POOL_SIZE=10
MYSQL_MAX_OVERFLOW=20
MYSQL_POOL_RECYCLE=1800
